# Server Config
MAIN_SERVER=IP_MAIN

# KAFKA CONFIG
KAFKA_SERVER=IP_KAFKA:9092
KAFKA_TOPIC=soc-raw-logs

# CLICKHOUSE CONFIG
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASS=your_password_here

# DASHBOARD AUTH
DASH_USER=your_username_here
DASH_PASS=your_password_here

ALLOWED_ORIGINS=http://localhost:8000,http://KAFKA_SERVER_IP_HERE

# POSTGRESQL CONFIGURATION
PG_USER=soc_admin
PG_PASS=YOUR_PASSWORD_HERE
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=soc_main_db

# Chuỗi kết nối dùng cho thư viện SQLAlchemy chuẩn bị cài đặt
DATABASE_URL=postgresql://${PG_USER}:${PG_PASS}@${PG_HOST}:${PG_PORT}/${PG_DB}